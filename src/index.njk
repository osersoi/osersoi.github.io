---
layout: base.njk
title: {{ site.subtitle }}
description: "{{ site.name }} - {{ site.description }}"
---

<!-- Hero Section -->
<section id="accueil" class="hero">
    <div class="hero-parallax" style="background-image: url('/images/hero-bg.png');"></div>
    <div class="hero-overlay"></div>
    <div class="container">
        <div class="hero-content">
            <p class="hero-subtitle">{{ site.subtitle }}</p>
            <h2>Osez révéler vos ressources intérieures</h2>
            <p class="lead">Vous ressentez le besoin de changement mais ne savez pas par où commencer ? L'hypnose Ericksonienne peut vous aider à activer vos propres ressources pour avancer sereinement vers le mieux-être.</p>
            <div class="hero-buttons">
                <a href="#"
                   class="btn-primary"
                   data-cal-link="{{ site.calcom }}"
                   data-cal-config='{"layout":"month_view"}'>
                   Prendre rendez-vous
                </a>
                <a href="#methode" class="btn-ghost">Découvrir l'approche</a>
            </div>
        </div>
    </div>
    <div class="hero-wave"></div>
</section>

<!-- Section Accompagnement -->
{% for genre in accompagnement.genres %}
<section id="accompagnement{% if genre.id != 'adultes' %}-{{ genre.id }}{% endif %}" class="accompagnement">
    <div class="container">
        <p class="section-label">{{ genre.section_label }}</p>
        <h2>{{ genre.section_title }}</h2>
        <p class="section-intro">{{ genre.section_intro }}</p>

        <div class="cards-grid">
            {% for card in genre.cards %}
            <div class="card">
                <div class="card-icon" aria-hidden="true">{{ card.icon }}</div>
                <h3>{{ card.title }}</h3>
                <p>{{ card.description }}</p>
            </div>
            {% endfor %}
        </div>
    </div>
</section>
{% endfor %}

<!-- Section À Propos -->
<section id="a-propos" class="about">
    <div class="container">
        <div class="about-grid">
            <div class="about-image">
                <picture>
                    <img src="/images/portrait.webp"
                         alt="Hypnothérapeute à Corsier-sur-Vevey"
                         loading="lazy">
                </picture>
            </div>
            <div class="about-content">
                <p class="section-label">{{ a_propos.section_label }}</p>
                <h2>{{ site.therapist }}{{ a_propos.title_suffix }}</h2>

                <p class="intro">{{ a_propos.intro }}</p>

                {% for paragraph in a_propos.content_paragraphs %}
                <p>{{ paragraph | safe }}</p>
                {% endfor %}

                                <div class="certifications">
                    <h3>{{ a_propos.certifications_title }}</h3>
                    <div class="certif-grid">
                        <ul>
                            {% for certification in a_propos.certifications %}
                            {% if loop.index <= (a_propos.certifications.length / 2) %}
                            <li>{{ certification }}</li>
                            {% endif %}
                            {% endfor %}
                        </ul>
                        <ul>
                            {% for certification in a_propos.certifications %}
                            {% if loop.index > (a_propos.certifications.length / 2) %}
                            <li>{{ certification }}</li>
                            {% endif %}
                            {% endfor %}
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Section Méthode -->
<section id="methode" class="methode">
    <div class="container">
        <p class="section-label">{{ methode.section_label }}</p>
        <h2>{{ methode.title }}</h2>
        <p class="section-intro">{{ methode.intro }}</p>

                <div class="methode-grid">
            {% for item in methode.items %}
            <div class="methode-item">
                <h3>{{ item.title }}</h3>
                <p>{{ item.description }}</p>
                <ul>
                    {% for detail in item.details %}
                    <li>{{ detail }}</li>
                    {% endfor %}
                </ul>
            </div>
            {% if not loop.last %}
            <div class="methode-divider" aria-hidden="true">
                <span>&</span>
            </div>
            {% endif %}
            {% endfor %}
        </div>

                <div class="methode-result">
            <h3>{{ methode.result_title }}</h3>
            <p>{{ methode.result_content | safe }}</p>
        </div>
    </div>
</section>

<!-- Section Tarifs -->
<section id="tarifs" class="tarifs">
    <div class="container">
        <p class="section-label">Tarifs & Modalités</p>
        <h2>Tarifs & Modalités</h2>

        <div class="tarifs-grid">
            {% for tarif in tarifs.items %}
            <div class="tarif-card{% if tarif.featured %} featured{% endif %}">
                <div class="tarif-badge">{{ tarif.badge }}</div>
                <h3>{{ tarif.title }}</h3>
                <div class="tarif-price">
                    <span class="price">{{ tarif.price }}</span>
                    {% if tarif.price_old %}
                    <span class="price-old">{{ tarif.price_old }}</span>
                    {% endif %}
                    {% if tarif.promo %}
                    <span class="promo">{{ tarif.promo }}</span>
                    {% endif %}
                </div>
                <p class="tarif-duration">{{ tarif.duration }}</p>
                <ul>
                    {% for detail in tarif.details %}
                    <li>{{ detail }}</li>
                    {% endfor %}
                </ul>
            </div>
            {% endfor %}
        </div>

        <div class="tarifs-info">
            <h3>Informations pratiques</h3>
            <div class="info-grid">
                <div class="info-item">
                    <strong>💳 Paiement</strong>
                    <p>Comptant à chaque séance<br>Cash ou Twint</p>
                </div>
                <div class="info-item">
                    <strong>📅 Annulation</strong>
                    <p>Au plus tard 48h avant la séance<br>Par SMS ou WhatsApp</p>
                </div>
                <div class="info-item">
                    <strong>⚠️ Important</strong>
                    <p>Toute séance non annulée dans les délais reste due</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Section Contact -->
<section id="contact" class="contact">
    <div class="container">
        <p class="section-label">Contact</p>
        <h2>Prendre rendez-vous</h2>
        <p class="section-intro">Un premier échange pour faire connaissance et répondre à vos questions.</p>

        <div class="contact-grid">
            <div class="contact-info">
                <h3>Prendre rendez-vous</h3>
                <div id="cal-inline" style="width:100%; height: 600px; overflow: auto;"></div>
                <script>
                  window.addEventListener('load', () => {
                    Cal("inline", {
                      elementOrSelector: "#cal-inline",
                      calLink: "{{ site.calcom }}",
                      config: {"layout":"month_view"}
                    });
                  });
                </script>
                <p>N'hésitez pas à me contacter directement avec le formulaire si vous avez des questions, ou utilisez le calendrier ci-dessus pour prendre rendez-vous.</p>
            </div>

            <div class="contact-form">
                <h3>M'écrire un message</h3>
                <form action="https://api.web3forms.com/submit" method="POST">
                    <input type="hidden" name="access_key" value="{{ site.web3forms_key }}">
                    <input type="hidden" name="subject" value="Nouveau message - {{ site.name }}">
                    <input type="hidden" name="redirect" value="{{ site.url }}/merci/">
                    <input type="checkbox" name="botcheck" aria-hidden="true" class="hidden" style="display:none">

                    <div class="form-group">
                        <label for="name">Votre nom *</label>
                        <input type="text" id="name" name="name" required>
                    </div>
                    <div class="form-group">
                        <label for="email">Votre email *</label>
                        <input type="email" id="email" name="email" required>
                    </div>
                    <div class="form-group">
                        <label for="phone">Votre téléphone</label>
                        <input type="tel" id="phone" name="phone">
                    </div>
                    <div class="form-group">
                        <label for="message">Votre message *</label>
                        <textarea id="message" name="message" rows="5" required></textarea>
                    </div>

                    <div class="h-captcha" aria-hidden="true" data-captcha="true"></div>

                    <button type="submit" class="btn-primary">Envoyer le message</button>
                    <p class="form-note">* Champs obligatoires. Vos données restent confidentielles.</p>
                </form>
            </div>
        </div>
    </div>
</section>

